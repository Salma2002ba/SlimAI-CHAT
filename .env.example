# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: Public URL of the SlimAI frontend (GitHub Pages, custom domain, etc.)
APP_URL="https://my-slimai-frontend.example.com"

# BACKEND_URL: URL of the future FastAPI backend.
# For local docker-compose, this will typically be http://backend:8000
BACKEND_URL="http://localhost:8000"

# PostgreSQL base configuration (used by docker-compose and backend)
POSTGRES_DB="slimai"
POSTGRES_USER="slimai_user"
POSTGRES_PASSWORD="slimai_password"

# DATABASE_URL: standard PostgreSQL connection string for the backend.
# In Docker, the host is the postgres service name.
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}"

