# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: Public URL of the SlimAI frontend (GitHub Pages, custom domain, etc.)
APP_URL="https://my-slimai-frontend.example.com"

# BACKEND_URL: URL of the FastAPI backend (browser / frontend). Use localhost when the UI runs on your machine.
BACKEND_URL="http://localhost:8000"

# PostgreSQL (docker-compose + local tools)
POSTGRES_DB="slimai"
POSTGRES_USER="slimai_user"
POSTGRES_PASSWORD="slimai_password"

# DATABASE_URL: used when you run the backend on the host (uvicorn), not inside Compose.
# Example for local Postgres on the default port:
# DATABASE_URL="postgresql://slimai_user:slimai_password@localhost:5432/slimai"
#
# Inside docker-compose, DATABASE_URL is set automatically for the backend service (host name: postgres).

# CORS_ORIGINS: comma-separated list of browser origins allowed to call the API.
CORS_ORIGINS="http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080"
