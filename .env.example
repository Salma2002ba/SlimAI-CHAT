# --- Backend (Railway / local uvicorn) ---
# Railway: reference Postgres → DATABASE_URL (secret). Optional: CORS_ORIGINS.
#
# CORS_ORIGINS examples (one line):
#   https://a.com,https://b.com
#   "https://a.com","https://b.com"
#   ["https://a.com","https://b.com"]

DATABASE_URL="postgresql://user:password@localhost:5432/slimai"
CORS_ORIGINS="http://localhost:5173,http://localhost:8080"

# --- Frontend (local / Docker build with Gemini) ---
GEMINI_API_KEY="your-google-ai-api-key"
