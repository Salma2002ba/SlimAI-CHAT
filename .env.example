# --- Backend (Railway / local) ---
# Postgres: DATABASE_URL (+ CORS_ORIGINS). Gemini: GEMINI_API_KEY (server only).

DATABASE_URL="postgresql://user:password@localhost:5432/slimai"
CORS_ORIGINS="http://localhost:5173,http://localhost:8080"
GEMINI_API_KEY=""

# CHAT_PROVIDER: auto | mock | gemini | rag
#   auto = Gemini if GEMINI_API_KEY set, else mock
#   rag  = retrieval-only (BM25), no LLM — parfait démo sans quota
CHAT_PROVIDER="auto"
# GEMINI_FALLBACK_MOCK_ON_429="true"

# RAG (Markdown sous backend/knowledge/)
RAG_ENABLED="true"
RAG_TOP_K="4"
RAG_CHUNK_SIZE="700"
RAG_CHUNK_OVERLAP="120"
# RAG_KNOWLEDGE_DIR="/chemin/vers/knowledge"

# --- Frontend (local Vite) ---
VITE_API_BASE_URL="http://localhost:8000"
