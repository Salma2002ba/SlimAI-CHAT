# --- Backend (Railway / local) ---
# Postgres: DATABASE_URL (+ CORS_ORIGINS). Gemini chat proxy: GEMINI_API_KEY (server only, never in frontend).
# Optional: GEMINI_MODEL (default gemini-2.0-flash)

DATABASE_URL="postgresql://user:password@localhost:5432/slimai"
CORS_ORIGINS="http://localhost:5173,http://localhost:8080"
GEMINI_API_KEY=""

# --- Frontend (local Vite) ---
# Base URL of the FastAPI app (no trailing slash). GitHub Actions: repository secret VITE_API_BASE_URL.
VITE_API_BASE_URL="http://localhost:8000"
